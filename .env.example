# Database (SQLite for local dev — use Vercel Postgres for production)
DATABASE_URL="file:./db/custom.db"

# ─── GoHighLevel (GHL) Integration ────────────────────────────────────
# Private Integration Token (PIT) — for server-side API calls
# Used by: /api/leads, /api/partners, /api/ghl, ghl-api.ts
GHL_API_KEY="pit-8a794f2b-5277-4ac4-80a0-1e1c3d3669b4"

# GHL Company ID (found in GHL Settings → Company)
GHL_COMPANY_ID=""

# GHL Location/Sub-Account ID (found in GHL Settings → Location)
GHL_LOCATION_ID=""

# ─── Auth (optional — uncomment when using NextAuth) ────────────────
# NEXTAUTH_SECRET="your-secret-here"
# NEXTAUTH_URL="https://your-domain.vercel.app"
